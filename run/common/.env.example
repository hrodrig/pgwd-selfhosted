# pgwd-selfhosted — template for Docker Compose variable substitution. Do not commit real secrets.
#
# This repository’s own semver is in VERSION at the repository root — bump for infra/doc/layout releases, not for app code.
#
# Recommended: keep SQLite and this file under one host directory (outside the git clone).
#   1. export PGWD_HOST_DATA=/home/pgwd/pgwd-data   # example
#   2. mkdir -p "$PGWD_HOST_DATA"
#   3. Copy this file to "${PGWD_HOST_DATA}/.env" and edit secrets.
#   4. Set PGWD_HOST_DATA in that .env to the same absolute path (required for volume mounts).
#   5. From the clone root:
#        docker compose --env-file "${PGWD_HOST_DATA}/.env" -f run/docker-compose/minimal/docker-compose.yml up -d
#   See run/docker-compose/README.md for minimal vs Traefik vs observability.
#
# Optional (local dev only): copy to ./.env at the repository root and leave PGWD_HOST_DATA unset — Compose
# falls back to the repo’s data/ directory (see run/docker-compose/*/docker-compose.yml).
#
# Observability (optional): same PGWD_HOST_DATA as above — copy
#   run/docker-compose/observability/observability.env.example → ${PGWD_HOST_DATA}/.env.observability
# and use --env-file "${PGWD_HOST_DATA}/.env.observability" on every observability compose command (-p pgwd-obs).

# --- pgwd (required for minimal / Traefik) ---
# Postgres connection URL (same as PGWD_DB_URL in the upstream docs).
PGWD_DB_URL=

# OCI image for the pgwd service. Prefer the public GHCR image + tag (below), or set a full override:
#   PGWD_IMAGE=hcr.example.com/library/pgwd:v0.5.11-dev
# When PGWD_IMAGE is set, Compose ignores the ghcr.io/...:${PGWD_VERSION} default.
# Unrelated to the pgwd-selfhosted VERSION file (manifests repo).
# PGWD_IMAGE=
PGWD_VERSION=v0.5.10

# Host directory bind-mounted to /var/lib/pgwd in the container (SQLite). Prefer an absolute path on servers, e.g.:
#   /home/pgwd/pgwd-data
#   /var/lib/pgwd
# If unset, Compose uses the repository data/ directory (see run/docker-compose/*/docker-compose.yml).
# Uncomment and set when using "${PGWD_HOST_DATA}/.env" (recommended on servers):
# PGWD_HOST_DATA=/home/pgwd/pgwd-data

# --- run/docker-compose/minimal/docker-compose.yml (optional overrides) ---
# Host port published as HOST:8080 (container always listens on 8080)
# PGWD_HOST_PORT=8080
PGWD_CLIENT=pgwd-compose
PGWD_INTERVAL=60
PGWD_LOG_LEVEL=info
# pgwd needs at least one notifier (below) OR dry-run. Without both, the process exits and the container restarts in a loop.
# Minimal compose defaults PGWD_DRY_RUN=true if unset; Traefik defaults it false — set true here until Slack/Loki are configured.
PGWD_DRY_RUN=true
# Optional notifiers (leave empty when using dry-run only)
PGWD_NOTIFICATIONS_SLACK_WEBHOOK=
PGWD_NOTIFICATIONS_LOKI_URL=

# --- run/docker-compose/traefik/docker-compose.yml (Traefik + TLS) ---
PGWD_HOSTNAME=pgwd.example.com
ACME_EMAIL=you@example.com
# Numeric UID/GID for the pgwd container user; must own PGWD_HOST_DATA (or repo data/ if unset)
PGWD_UID=1000
PGWD_GID=1000

# --- Observability — template: run/docker-compose/observability/observability.env.example → ${PGWD_HOST_DATA}/.env.observability ---
