# pgwd-selfhosted — observability env for docker compose (Grafana, Prometheus ports, etc.). Do not commit real passwords.
#
# Use the SAME host directory as the main Compose stack (same PGWD_HOST_DATA as "${PGWD_HOST_DATA}/.env").
# Recommended:
#   1. export PGWD_HOST_DATA=/home/pgwd/pgwd-data   # must match your main .env
#   2. mkdir -p "$PGWD_HOST_DATA"
#   3. cp run/docker-compose/observability/observability.env.example "${PGWD_HOST_DATA}/.env.observability"
#   4. Edit secrets (at least GRAFANA_ADMIN_PASSWORD before first Grafana start).
#   5. From the clone root, always pass this file to Compose, e.g.:
#        docker compose --env-file "${PGWD_HOST_DATA}/.env.observability" -p pgwd-obs \
#          -f run/docker-compose/observability/docker-compose.observability.yml up -d
#
# Do not keep a populated copy inside the git clone.

# Grafana reads these only on FIRST startup with an empty Grafana data volume.
# If you change them later in this file, login credentials do NOT update — they stay in the persisted DB.
# To rotate: Grafana UI (user profile), or `grafana-cli admin reset-admin-password`, or remove the grafana_data volume (destructive).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-before-first-up

# Host port for Grafana UI (avoid clashes with other services on the host)
GRAFANA_PORT=3000

# Must match how you open Grafana in the browser (Grafana redirects / cookies).
# Local only:
GRAFANA_ROOT_URL=http://localhost:3000
#
# HTTPS via Traefik (requires docker-compose.observability.traefik.yml alongside the base compose file).
# Set FQDN + https URL; DNS: A/AAAA to this host, or CNAME — same idea as PGWD_HOSTNAME for pgwd.
# Full two-file command: root README.md → section "Observability optional".
# GRAFANA_HOSTNAME=pgwd-obs.my-domain.com
# GRAFANA_ROOT_URL=https://pgwd-obs.my-domain.com

# Host port for Prometheus UI
PROMETHEUS_PORT=9090

# Node Exporter (host metrics; Grafana dashboard 1860). Default 9100.
NODE_EXPORTER_PORT=9100
