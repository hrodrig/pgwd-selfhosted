{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "replicaCount",
    "image",
    "serviceAccount",
    "config",
    "secrets",
    "http",
    "service",
    "persistence"
  ],
  "additionalProperties": false,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "required": ["repository", "pullPolicy"],
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "Never", "IfNotPresent"]
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 }
        }
      }
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "required": ["create", "name"],
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "additionalProperties": true
    },
    "securityContext": {
      "type": "object",
      "additionalProperties": true
    },
    "resources": {
      "type": "object",
      "additionalProperties": true
    },
    "nodeSelector": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "tolerations": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "affinity": {
      "type": "object",
      "additionalProperties": true
    },
    "config": {
      "type": "object",
      "required": ["enabled", "extra"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "extra": { "type": "string" }
      }
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["secretKeyRef"],
            "additionalProperties": false,
            "properties": {
              "secretKeyRef": {
                "type": "object",
                "required": ["name", "key"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "key": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        ]
      }
    },
    "secrets": {
      "type": "object",
      "required": ["create", "dbUrl", "slackWebhook", "lokiUrl", "existingSecret"],
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "dbUrl": { "type": "string" },
        "slackWebhook": { "type": "string" },
        "lokiUrl": { "type": "string" },
        "existingSecret": { "type": "string" }
      }
    },
    "http": {
      "type": "object",
      "required": [
        "enabled",
        "listen",
        "containerPort",
        "basePath",
        "healthPath",
        "metricsPath",
        "probePath",
        "probes"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "listen": { "type": "string", "minLength": 1 },
        "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "basePath": { "type": "string" },
        "healthPath": { "type": "string" },
        "metricsPath": { "type": "string" },
        "probePath": { "type": "string" },
        "probes": {
          "type": "object",
          "required": [
            "enabled",
            "initialDelaySeconds",
            "readinessInitialDelaySeconds",
            "periodSeconds",
            "timeoutSeconds",
            "failureThreshold"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "initialDelaySeconds": { "type": "integer", "minimum": 0 },
            "readinessInitialDelaySeconds": { "type": "integer", "minimum": 0 },
            "periodSeconds": { "type": "integer", "minimum": 1 },
            "timeoutSeconds": { "type": "integer", "minimum": 1 },
            "failureThreshold": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "service": {
      "type": "object",
      "required": ["enabled", "type", "port", "annotations"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "type": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "persistence": {
      "type": "object",
      "required": [
        "enabled",
        "storageClass",
        "accessMode",
        "size",
        "mountPath",
        "sqliteFile",
        "subPath"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "storageClass": { "type": "string" },
        "accessMode": { "type": "string", "minLength": 1 },
        "size": { "type": "string", "minLength": 1 },
        "mountPath": { "type": "string", "minLength": 1 },
        "sqliteFile": { "type": "string", "minLength": 1 },
        "subPath": { "type": "string" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "config": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          }
        },
        "required": ["config"]
      },
      "then": {
        "properties": {
          "config": {
            "properties": {
              "extra": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "persistence": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          }
        },
        "required": ["persistence"]
      },
      "then": {
        "properties": {
          "replicaCount": { "type": "integer", "minimum": 1, "maximum": 1 }
        },
        "required": ["replicaCount"]
      }
    }
  ]
}
