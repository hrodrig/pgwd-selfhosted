{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "replicaCount",
    "image",
    "serviceAccount",
    "config",
    "secrets"
  ],
  "additionalProperties": false,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "required": ["repository", "pullPolicy"],
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "Never", "IfNotPresent"]
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 }
        }
      }
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "required": ["create", "name"],
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "additionalProperties": true
    },
    "securityContext": {
      "type": "object",
      "additionalProperties": true
    },
    "resources": {
      "type": "object",
      "additionalProperties": true
    },
    "nodeSelector": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "tolerations": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "affinity": {
      "type": "object",
      "additionalProperties": true
    },
    "config": {
      "type": "object",
      "required": ["enabled", "extra"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "extra": { "type": "string" }
      }
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["secretKeyRef"],
            "additionalProperties": false,
            "properties": {
              "secretKeyRef": {
                "type": "object",
                "required": ["name", "key"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "key": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        ]
      }
    },
    "secrets": {
      "type": "object",
      "required": ["create", "dbUrl", "slackWebhook", "lokiUrl", "existingSecret"],
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "dbUrl": { "type": "string" },
        "slackWebhook": { "type": "string" },
        "lokiUrl": { "type": "string" },
        "existingSecret": { "type": "string" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "config": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          }
        },
        "required": ["config"]
      },
      "then": {
        "properties": {
          "config": {
            "properties": {
              "extra": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  ]
}
