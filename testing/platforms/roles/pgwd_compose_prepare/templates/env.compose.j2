# Generated by Ansible (pgwd-selfhosted testing/platforms) — do not commit.
PGWD_DB_URL={{ pgwd_db_url }}
PGWD_VERSION={{ pgwd_image_version }}
PGWD_HOST_DATA={{ pgwd_host_data }}
PGWD_HOST_PORT={{ pgwd_host_port | default(8080) }}
PGWD_CLIENT={{ pgwd_client | default('pgwd-compose-ansible') }}
PGWD_INTERVAL={{ pgwd_interval | default(60) }}
PGWD_LOG_LEVEL={{ pgwd_log_level | default('info') }}
PGWD_DRY_RUN={% if pgwd_dry_run | default(true) %}true{% else %}false{% endif %}

{% if pgwd_notifications_slack_webhook is defined and pgwd_notifications_slack_webhook | length > 0 %}
PGWD_NOTIFICATIONS_SLACK_WEBHOOK={{ pgwd_notifications_slack_webhook }}
{% endif %}
{% if pgwd_notifications_loki_url is defined and pgwd_notifications_loki_url | length > 0 %}
PGWD_NOTIFICATIONS_LOKI_URL={{ pgwd_notifications_loki_url }}
{% endif %}
